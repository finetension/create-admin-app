{
	"name": "create-admin-app-monorepo",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"bin": {
		"cli": "./dist/cli/index.mjs"
	},
	"packageManager": "pnpm@11.15.1",
	"engines": {
		"node": ">=22.13.0",
		"pnpm": ">=11.0.0 <12.0.0"
	},
	"scripts": {
		"cli": "vite build --config ./vite.cli.config.ts --logLevel silent && node ./dist/cli/index.mjs",
		"cli:build": "vite build --config ./vite.cli.config.ts",
		"cli:dev": "tsx ./src/cli/index.ts",
		"dev": "pnpm cli dev",
		"build": "pnpm cli build",
		"preview": "pnpm run build && vite preview",
		"deploy:check": "pnpm cli check --config ./deploy.config.json",
		"types": "wrangler types --strict-vars=false worker-configuration.d.ts",
		"types:check": "wrangler types --strict-vars=false --check worker-configuration.d.ts",
		"db:migrate:local": "pnpm cli db migrate",
		"db:reset:local": "pnpm cli db reset",
		"db:seed:local": "pnpm cli db seed",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "pnpm run lint:biome && pnpm run lint:eslint && pnpm run lint:fsd",
		"lint:biome": "biome lint .",
		"lint:eslint": "eslint src/web",
		"lint:fsd": "steiger ./src/web",
		"type-check": "tsc -b --pretty false",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"generator:prepare": "pnpm --filter @finetension/create-admin-app prepare:template",
		"generator:build": "pnpm --filter @finetension/create-admin-app build",
		"generator:test": "pnpm --filter @finetension/create-admin-app test",
		"generator:check": "pnpm run generator:build && pnpm run generator:test",
		"create": "pnpm run generator:prepare && pnpm run generator:build && node ./packages/create-admin-app/dist/index.js",
		"check": "pnpm run types:check && pnpm run type-check && biome check . && pnpm run lint:eslint && pnpm run lint:fsd && pnpm run test && pnpm run build && pnpm run generator:check"
	},
	"dependencies": {
		"@heroui/react": "3.2.2",
		"@heroui/styles": "3.2.2",
		"@tanstack/react-query": "5.101.2",
		"es-hangul": "2.4.0",
		"hono": "4.12.30",
		"jose": "6.2.3",
		"lucide-react": "1.24.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-router": "8.2.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@cloudflare/vite-plugin": "1.45.0",
		"@cloudflare/workers-types": "5.20260717.1",
		"@napi-rs/keyring": "1.3.0",
		"@feature-sliced/steiger-plugin": "^0.7.0",
		"@tailwindcss/vite": "4.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"citty": "0.2.2",
		"consola": "3.4.2",
		"eslint": "^10.7.0",
		"execa": "9.6.1",
		"jsonc-parser": "3.3.1",
		"ofetch": "1.5.1",
		"steiger": "^0.6.0",
		"tailwindcss": "4.3.2",
		"tsx": "4.23.1",
		"typescript": "6.0.2",
		"typescript-eslint": "^8.64.0",
		"vite": "8.1.4",
		"vitest": "4.1.10",
		"wrangler": "4.111.0"
	}
}
