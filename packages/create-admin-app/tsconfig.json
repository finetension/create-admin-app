{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck": true,
		"types": ["node"],
		"rootDir": "./src",
		"outDir": "./dist"
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts"]
}
